APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=notifications_postgresql
DB_READ_HOST=notifications_postgresql_replica
DB_PORT=5432
DB_DATABASE=notifications
DB_USERNAME=notifications
DB_PASSWORD=notifications

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=notifications_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=notifications_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=notifications
RABBITMQ_PASSWORD=notifications
RABBITMQ_VHOST=/

RABBITMQ_QUEUE=notifications
RABBITMQ_QUEUE_SMS_HIGH=notifications_sms_high
RABBITMQ_QUEUE_SMS_LOW=notifications_sms_low
RABBITMQ_QUEUE_EMAIL_HIGH=notifications_email_high
RABBITMQ_QUEUE_EMAIL_LOW=notifications_email_low
RABBITMQ_PREFETCH=30

IDEMPOTENCY_TTL=3600
PROVIDER_WEBHOOK_SECRET=local-provider-secret

SMS_RATE_LIMIT_PER_SECOND=200
EMAIL_RATE_LIMIT_PER_SECOND=400

L5_SWAGGER_GENERATE_ALWAYS=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
