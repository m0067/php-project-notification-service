APP_NAME=Laravel
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=notifications_postgresql
# Read from the primary in tests so assertions never race replication lag.
DB_READ_HOST=notifications_postgresql
DB_PORT=5432
DB_DATABASE=notifications_test
DB_USERNAME=notifications
DB_PASSWORD=notifications

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq

CACHE_STORE=redis
REDIS_CACHE_DB=2

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=notifications_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=notifications_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=notifications
RABBITMQ_PASSWORD=notifications
RABBITMQ_VHOST=/

RABBITMQ_QUEUE=test_notifications_sms_low
RABBITMQ_QUEUE_SMS_HIGH=test_notifications_sms_high
RABBITMQ_QUEUE_SMS_LOW=test_notifications_sms_low
RABBITMQ_QUEUE_EMAIL_HIGH=test_notifications_email_high
RABBITMQ_QUEUE_EMAIL_LOW=test_notifications_email_low
RABBITMQ_PREFETCH=10

IDEMPOTENCY_TTL=3600
PROVIDER_WEBHOOK_SECRET=test-provider-secret

L5_SWAGGER_GENERATE_ALWAYS=false

MAIL_MAILER=array

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false
